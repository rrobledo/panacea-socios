{
  "rewrites": [
    {
      "source": "/socios/:path*",
      "destination": "https://panacea-socios-backend-o9awt0img-rauls-projects-d37b0ed8.vercel.app/socios/:path*"
    },
    {
      "source": "/ventas/:path*",
      "destination": "https://panacea-socios-backend-o9awt0img-rauls-projects-d37b0ed8.vercel.app/ventas/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
